#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

# Load secrets from .env
if [ -f "${PROJECT_DIR}/.env" ]; then
  set -a; source "${PROJECT_DIR}/.env"; set +a
fi

: "${SSH_KEY:?Set SSH_KEY in .env}"
: "${SERVER_USER:?Set SERVER_USER in .env}"
: "${SERVER_IP:?Set SERVER_IP in .env}"

SERVER_PATH="/home/${SERVER_USER}/projects/PicTinder/website"
SSH_CMD="ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no ${SERVER_USER}@${SERVER_IP}"

echo "==> Deploying website to ${SERVER_USER}@${SERVER_IP}:${SERVER_PATH}"

$SSH_CMD "mkdir -p ${SERVER_PATH}/downloads"

rsync -avz --delete \
  --exclude='deploy.sh' \
  -e "ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no" \
  "${PROJECT_DIR}/website/" \
  "${SERVER_USER}@${SERVER_IP}:${SERVER_PATH}/"

echo "==> Website files synced."

# nginx — only write config if it doesn't exist (preserves certbot SSL changes)
$SSH_CMD << 'REMOTE'
set -euo pipefail

DOMAIN="pictinder.com"
WEB_ROOT="/home/azureuser/projects/PicTinder/website"
NGINX_CONF="/etc/nginx/sites-available/${DOMAIN}"

if ! command -v nginx &>/dev/null; then
  sudo apt-get update -qq
  sudo apt-get install -y -qq nginx
fi

if [ ! -f "$NGINX_CONF" ]; then
  echo "==> First deploy — writing nginx config…"

  if ! command -v certbot &>/dev/null; then
    sudo apt-get install -y -qq certbot python3-certbot-nginx
  fi

  sudo tee "$NGINX_CONF" > /dev/null << 'NGINX'
server {
    listen 80;
    listen [::]:80;
    server_name pictinder.com www.pictinder.com;

    root /home/azureuser/projects/PicTinder/website;
    index index.html;

    location /api/ {
        proxy_pass http://127.0.0.1:4100/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri.html $uri/ =404;
    }

    location ~* \.(css|js|jpg|jpeg|png|gif|webp|svg|ico|woff2?)$ {
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }

    location /downloads/ {
        types {
            application/x-apple-diskimage dmg;
            application/zip zip;
        }
        add_header Content-Disposition "attachment";
    }

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
}
NGINX

  sudo ln -sf "$NGINX_CONF" "/etc/nginx/sites-enabled/${DOMAIN}"
  sudo rm -f /etc/nginx/sites-enabled/default

  echo ""
  echo "⚠  Run certbot to enable SSL:"
  echo "    sudo certbot --nginx -d ${DOMAIN} -d www.${DOMAIN}"
else
  echo "==> nginx config exists — preserving SSL. Reloading…"
fi

sudo nginx -t 2>&1 && sudo systemctl reload nginx

REMOTE

echo ""
echo "==> Website deployed: https://pictinder.com"
