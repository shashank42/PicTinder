{
  "name": "pictinder",
  "version": "1.0.0",
  "description": "Tinder for pictures — shortlist photos/videos from a folder by swiping",
  "main": "main.js",
  "scripts": {
    "postinstall": "electron-rebuild",
    "rebuild": "electron-rebuild",
    "rebuild:win": "node scripts/run-rebuild-with-vs.js",
    "start": "electron .",
    "run:dev": "node test-scripts/run.js",
    "build:test": "node test-scripts/build-and-run.js",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "deploy:mac": "node scripts/deploy.js mac",
    "deploy:win": "node scripts/deploy.js win",
    "deploy:app": "node scripts/deploy.js",
    "deploy:website": "bash scripts/deploy-website",
    "deploy:license": "bash scripts/deploy-licensing-server"
  },
  "keywords": [
    "electron",
    "photos",
    "shortlist",
    "tinder"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vladmandic/human": "^3.3.6",
    "better-sqlite3": "^12.6.2",
    "canvas": "^3.2.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^17.3.1",
    "electron-store": "^8.1.0",
    "express": "^4.18.2",
    "qrcode": "^1.5.3",
    "sharp": "^0.34.5",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.pictinder.app",
    "productName": "PicTinder",
    "directories": {
      "output": "dist"
    },
    "afterPack": "scripts/afterPack.js",
    "asarUnpack": [
      "**/better-sqlite3/**",
      "**/sharp/**",
      "**/canvas/**",
      "**/@img/**",
      "**/@tensorflow/**",
      "**/@vladmandic/human/**"
    ],
    "mac": {
      "category": "public.app-category.photos",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": "Developer ID Application",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": {
        "teamId": "9Z83RNNA48"
      }
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    }
  }
}
