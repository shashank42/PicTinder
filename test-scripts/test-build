#!/usr/bin/env bash
set -e

cd "$(dirname "$0")/.."

if [ ! -d node_modules ]; then
  echo "Installing dependencies..."
  npm install
fi

if [[ "$OSTYPE" == msys* ]] || [[ "$OSTYPE" == cygwin* ]]; then
  echo ""
  echo "=== Building fast test Windows app ==="
  npm run rebuild:win
  npm run build:win

  echo ""
  echo "Build output is in ./dist/"
  ls -1 dist/*.exe 2>/dev/null || true

  EXE=$(find dist -maxdepth 1 -name "*.exe" | grep -iv Setup | head -1)
  if [ -n "$EXE" ]; then
    echo ""
    echo "Launching $EXE ..."
    start "" "$EXE"
  else
    echo "No portable .exe found in dist/. Open it manually from dist/."
  fi
elif [[ "$OSTYPE" == darwin* ]]; then
  echo ""
  echo "=== Building fast test macOS app (Unsigned) ==="
  npm run build:mac -- -c.mac.identity=null -c.mac.hardenedRuntime=false

  echo ""
  echo "Build output is in ./dist/"
  ls -1 dist/*.dmg dist/*.zip dist/*.exe 2>/dev/null || true

  APP=$(find dist/mac* -name "PicTinder.app" -maxdepth 2 2>/dev/null | head -1)
  if [ -n "$APP" ]; then
    echo ""
    echo "Launching $APP ..."
    xattr -cr "$APP" 2>/dev/null || true
    open "$APP"
  else
    echo "Mac .app not found in dist/. Open it manually from dist/."
  fi
else
  echo "Unsupported platform. Run electron-builder manually."
fi
